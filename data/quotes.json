[
  {
    "id": "q_1741675401",
    "content": "球不落地，永不放弃。",
    "author": "羽坛金句",
    "createdAt": "2026-03-11T00:00:01.000Z"
  },
  {
    "id": "q_1741675402",
    "content": "先到位，再发力；先稳定，再得分。",
    "author": "羽坛金句",
    "createdAt": "2026-03-11T00:00:02.000Z"
  },
  {
    "id": "q_1741675403",
    "content": "每一次多拍，都是下一次赢球的底气。",
    "author": "羽坛金句",
    "createdAt": "2026-03-11T00:00:03.000Z"
  },
  {
    "id": "q_1741675404",
    "content": "练习不是重复昨天，而是超越昨天。",
    "author": "羽坛金句",
    "createdAt": "2026-03-11T00:00:04.000Z"
  }
]
