generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  icon      String?
  order     Int        @default(0)
  parentId  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  keywords  String?
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  articles  Article[]  @relation("ArticleCategories")
}

model Article {
  id         String      @id @default(uuid())
  title      String
  content    String
  court_area CourtArea?
  difficulty Difficulty?
  video_url  String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  categories Category[]  @relation("ArticleCategories")
  tags       Tag[]       @relation("ArticleToTag")
}

model Tag {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  articles  Article[] @relation("ArticleToTag")
}

model QaHistory {
  id             String   @id @default(uuid())
  question       String
  answer         String?
  citations_json String?
  createdAt      DateTime @default(now())
  articleId      String?
}

model TagClick {
  id            String   @id @default(uuid())
  tag           String   @unique
  count         Int      @default(1)
  lastClickedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum CourtArea {
  Net
  Mid
  Rear
  Full
}

enum Difficulty {
  L1_Beginner
  L2_Amateur
  L3_Advanced
  L4_Pro
}
