generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  keywords  String?    // Keywords for SEO or auto-matching
  icon      String?    // Stores Lucide icon name (e.g., "Dumbbell", "Footprints")
  order     Int        @default(0)
  
  // Self-relation for hierarchy
  parentId  String?
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  
  articles  Article[]  @relation("ArticleCategories") // Many-to-Many relation
  
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Article {
  id          String      @id @default(uuid())
  title       String
  content     String      // Stores HTML or JSON from TipTap
  
  // Domain Specific Fields
  court_area  CourtArea?
  difficulty  Difficulty?
  video_url   String?
  
  // Relations
  categories  Category[]  @relation("ArticleCategories") // Many-to-Many
  tags        Tag[]
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Tag {
  id        String    @id @default(uuid())
  name      String    @unique // 标签名，如 "杀球"
  slug      String    @unique // URL用，如 "smash"
  articles  Article[] // 多对多关联
  createdAt DateTime  @default(now())
}

enum CourtArea {
  Net     // 网前
  Mid     // 中场
  Rear    // 后场
  Full    // 全场
}

enum Difficulty {
  L1_Beginner
  L2_Amateur
  L3_Advanced
  L4_Pro
}
